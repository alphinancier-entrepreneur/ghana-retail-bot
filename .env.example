# Server
PORT=3000
NODE_ENV=development

# Supabase (from Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (from Twilio Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public URL of your server (needed later for Twilio webhook + signature checks)
# Local dev: use ngrok or similar, e.g. https://abc123.ngrok-free.app
PUBLIC_WEBHOOK_BASE_URL=https://your-public-url.example

# Anthropic (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional: override Claude model
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Free tier: messages per user per day (Ghana midnight reset)
# DAILY_FREE_LIMIT=20

# Comma-separated phones that skip the daily limit (admin + testers)
# UNLIMITED_USERS=+233201234567,+233501234567

# WhatsApp buttons (run: node scripts/setup-whatsapp-templates.js)
TWILIO_CONTENT_SID_WELCOME=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_MORE_MENU=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_BULK_HELP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
